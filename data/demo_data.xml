        <!-- Driving School Test 2 -->
        <record id="driving2_survey" model="test.survey">
            <field name="title">Driving School Test 2</field>
            <field name="description"><![CDATA[<p>Test your driving knowledge and safety skills!</p>]]></field>
            <field name="description_done"><![CDATA[<p>Thank you for completing the test!</p>]]></field>
            <field name="active">true</field>
            <field name="access_mode">public</field>
            <field name="questions_layout">page_per_question</field>
            <field name="questions_selection">all</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">80.0</field>
        </record>
        
        <!-- Driving Q1 -->
        <record id="driving2_q1" model="test.question">
            <field name="survey_id" ref="driving2_survey"/>
            <field name="question">How can driving schools help students overcome highway anxiety?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">1</field>
            <field name="is_scored">true</field>
            <field name="constr_mandatory">true</field>
            <field name="passing_score">80</field>
        </record>
        
        <!-- Driving Q1 Answer A (Correct) -->
        <record id="driving2_q1_a" model="test.question.answer">
            <field name="question_id" ref="driving2_q1"/>
            <field name="value">Start with short, low-traffic highway merges during off-peak hours.</field>
            <field name="is_correct">true</field>
            <field name="answer_score">1</field>
            <field name="sequence">1</field>
        </record>
        
        <!-- Driving Q1 Answer B -->
        <record id="driving2_q1_b" model="test.question.answer">
            <field name="question_id" ref="driving2_q1"/>
            <field name="value">Use simulated highway scenarios in a driving simulator first.</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">2</field>
        </record>
        
        <!-- Driving Q1 Answer C -->
        <record id="driving2_q1_c" model="test.question.answer">
            <field name="question_id" ref="driving2_q1"/>
            <field name="value">Pair anxious students with calm, experienced instructors for gradual exposure.</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">3</field>
        </record>
        
