<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Demo Test Survey -->
        <record id="demo_test_survey" model="test.survey">
            <field name="title">Sample Test - Demo</field>
            <field name="description"><![CDATA[<p>This is a demo test for students to practice.</p>]]></field>
            <field name="description_done"><![CDATA[<p>Thank you for completing the demo test!</p>]]></field>
            <field name="active">true</field>
            <field name="access_mode">public</field>
            <field name="questions_layout">page_per_question</field>
            <field name="questions_selection">all</field>
            <field name="scoring_type">scoring_with_answers</field>
            <field name="scoring_success_min">70.0</field>
            <field name="is_time_limited">true</field>
            <field name="time_limit">15</field>
        </record>
        
        <!-- Demo Question 1 -->
        <record id="demo_question_1" model="test.question">
            <field name="survey_id" ref="demo_test_survey"/>
            <field name="question">What is Odoo?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">1</field>
            <field name="is_scored">true</field>
            <field name="constr_mandatory">true</field>
            <field name="passing_score">70</field>
        </record>
        
        <!-- Demo Answer 1.1 -->
        <record id="demo_answer_1_1" model="test.question.answer">
            <field name="question_id" ref="demo_question_1"/>
            <field name="value">A Python-based ERP system</field>
            <field name="is_correct">true</field>
            <field name="answer_score">10</field>
            <field name="sequence">1</field>
        </record>
        
        <!-- Demo Answer 1.2 -->
        <record id="demo_answer_1_2" model="test.question.answer">
            <field name="question_id" ref="demo_question_1"/>
            <field name="value">A database only</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">2</field>
        </record>
        
        <!-- Demo Answer 1.3 -->
        <record id="demo_answer_1_3" model="test.question.answer">
            <field name="question_id" ref="demo_question_1"/>
            <field name="value">A programming language</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">3</field>
        </record>
        
        <!-- Demo Question 2 -->
        <record id="demo_question_2" model="test.question">
            <field name="survey_id" ref="demo_test_survey"/>
            <field name="question">What programming language is Odoo written in?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">2</field>
            <field name="is_scored">true</field>
            <field name="constr_mandatory">true</field>
            <field name="passing_score">70</field>
        </record>
        
        <!-- Demo Answer 2.1 -->
        <record id="demo_answer_2_1" model="test.question.answer">
            <field name="question_id" ref="demo_question_2"/>
            <field name="value">Python</field>
            <field name="is_correct">true</field>
            <field name="answer_score">10</field>
            <field name="sequence">1</field>
        </record>
        
        <!-- Demo Answer 2.2 -->
        <record id="demo_answer_2_2" model="test.question.answer">
            <field name="question_id" ref="demo_question_2"/>
            <field name="value">Java</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">2</field>
        </record>
        
        <!-- Demo Answer 2.3 -->
        <record id="demo_answer_2_3" model="test.question.answer">
            <field name="question_id" ref="demo_question_2"/>
            <field name="value">PHP</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">3</field>
        </record>
        
        <!-- Demo Question 3 -->
        <record id="demo_question_3" model="test.question">
            <field name="survey_id" ref="demo_test_survey"/>
            <field name="question">What is MVC in web development?</field>
            <field name="question_type">multiple_choice</field>
            <field name="sequence">3</field>
            <field name="is_scored">true</field>
            <field name="constr_mandatory">true</field>
            <field name="passing_score">70</field>
        </record>
        
        <!-- Demo Answer 3.1 -->
        <record id="demo_answer_3_1" model="test.question.answer">
            <field name="question_id" ref="demo_question_3"/>
            <field name="value">Model View Controller</field>
            <field name="is_correct">true</field>
            <field name="answer_score">10</field>
            <field name="sequence">1</field>
        </record>
        
        <!-- Demo Answer 3.2 -->
        <record id="demo_answer_3_2" model="test.question.answer">
            <field name="question_id" ref="demo_question_3"/>
            <field name="value">Minimum Viable Code</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">2</field>
        </record>
        
        <!-- Demo Answer 3.3 -->
        <record id="demo_answer_3_3" model="test.question.answer">
            <field name="question_id" ref="demo_question_3"/>
            <field name="value">Microsoft Visual Code</field>
            <field name="is_correct">false</field>
            <field name="answer_score">0</field>
            <field name="sequence">3</field>
        </record>
        
        <!-- Demo Question 4 -->
        <record id="demo_question_4" model="test.question">
            <field name="survey_id" ref="demo_test_survey"/>
            <field name="question">Explain what Odoo modules are:</field>
            <field name="question_type">text_box</field>
            <field name="sequence">4</field>
            <field name="is_scored">false</field>
            <field name="constr_mandatory">true</field>
        </record>
        
        <!-- Demo Question 5 -->
        <record id="demo_question_5" model="test.question">
            <field name="survey_id" ref="demo_test_survey"/>
            <field name="question">How many years of experience do you have with Odoo?</field>
            <field name="question_type">numerical_box</field>
            <field name="sequence">5</field>
            <field name="is_scored">false</field>
            <field name="constr_mandatory">false</field>
        </record>
    </data>
</odoo>
