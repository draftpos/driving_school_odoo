<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Test Survey Form View -->
        <record id="test_survey_view_form" model="ir.ui.view">
            <field name="name">test.survey.view.form</field>
            <field name="model">test.survey</field>
            <field name="arch" type="xml">
                <form string="Test Survey">
                    <header>
                        <button name="action_send_test" string="Share" type="object" class="oe_highlight" invisible="not active"/>
                        <button name="action_result_test" string="See results" type="object" class="oe_highlight"/>
                        <button name="action_start_test" string="Test" type="object" invisible="not active or not question_ids"/>
                        <button name="action_archive" string="Close" type="object" invisible="not active"/>
                        <button name="action_unarchive" string="Reopen" class="btn-primary" type="object" invisible="active"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_test_user_input"
                                type="object"
                                class="oe_stat_button"
                                invisible="access_mode == 'public'"
                                icon="fa-envelope-o">
                                <field string="Registered" name="answer_count" widget="statinfo"/>
                            </button>
                            <button name="action_test_user_input_completed"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-square-o">
                                <field string="Participants" name="answer_done_count" widget="statinfo"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <field name="access_token" invisible="1"/>
                        <div class="oe_title" style="width: 100%;">
                            <h1>
                                <field name="title" options="{'line_breaks': False}" widget="text" placeholder="e.g. Test Survey"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_id" widget="many2one_avatar_user"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Questions" name="questions">
                                <field name="question_ids" nolabel="1" widget="one2many_list" mode="list">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="question"/>
                                        <field name="question_type"/>
                                        <field name="is_scored" optional="show"/>
                                    </list>
                                    <form string="Question">
                                        <field name="sequence" widget="handle"/>
                                        <group>
                                            <field name="question" placeholder="Enter your question"/>
                                            <field name="question_type"/>
                                            <field name="is_scored"/>
                                            <field name="passing_score" invisible="not is_scored"/>
                                            <field name="constr_mandatory"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page string="Description" name="description">
                                <field name="description" placeholder="e.g. The following Test will help us..." options="{'embedded_components': false}" nolabel="1"></field>
                            </page>
                            <page string="End Message" name="description_done">
                                <field name="description_done" placeholder="e.g. Thank you very much for completing this test!" options="{'embedded_components': false}" nolabel="1"></field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Test Survey List View -->
        <record id="test_survey_view_tree" model="ir.ui.view">
            <field name="name">test.survey.view.list</field>
            <field name="model">test.survey</field>
            <field name="arch" type="xml">
                <list string="Test Surveys">
                    <field name="active" column_invisible="True"/>
                    <field name="title"/>
                    <field name="user_id" widget="many2one_avatar_user"/>
                    <field name="question_count"/>
                    <field name="answer_count"/>
                    <field name="answer_done_count"/>
                </list>
            </field>
        </record>

        <!-- Test Survey Kanban View -->
        <record id="test_survey_view_kanban" model="ir.ui.view">
            <field name="name">test.survey.view.kanban</field>
            <field name="model">test.survey</field>
            <field name="arch" type="xml">
                <kanban highlight_color="color">
                    <field name="active"/>
                    <field name="color"/>
                    <templates>
                        <div t-name="card" t-attf-class="o_kanban_card #{record.active.raw_value ? '' : 'oe_kanban_inactive'}">
                            <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="title"/></strong>
                                <div class="o_kanban_tags_section">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                                <div class="o_kanban_inline_block">
                                    <field name="question_count"/> Questions
                                </div>
                                <div class="o_kanban_inline_block">
                                    <field name="answer_done_count"/> Participants
                                </div>
                            </div>
                        </div>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Test Survey Search View -->
        <record id="test_survey_view_search" model="ir.ui.view">
            <field name="name">test.survey.search</field>
            <field name="model">test.survey</field>
            <field name="arch" type="xml">
                <search string="Test Survey">
                    <field string="Test Survey" name="title"/>
                    <field name="user_id"/>
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <group>
                        <filter string="Responsible" name="group_by_responsible"
                            context="{'group_by': 'user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Test Actions -->
        <record id="action_test_survey" model="ir.actions.act_window">
            <field name="name">Tests</field>
            <field name="res_model">test.survey</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <record id="action_test_question" model="ir.actions.act_window">
            <field name="name">Questions</field>
            <field name="res_model">test.question</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_test_user_input" model="ir.actions.act_window">
            <field name="name">Responses</field>
            <field name="res_model">test.user_input</field>
            <field name="view_mode">list,form</field>
        </record>

<!-- Test Survey Menu -->
        <menuitem id="menu_test_root" name="Test" sequence="100" web_icon="test,static/description/icon.png"/>

<!-- Test App Link for Students -->
        <menuitem id="menu_test_portal" name="Take Test" parent="menu_test_root" action="action_test_survey" sequence="5"/>

        <!-- Test Surveys (Main Menu Item) -->
        <menuitem id="menu_test_surveys" name="Surveys" parent="menu_test_root" action="action_test_survey" sequence="10"/>

        <!-- Questions Menu -->
        <menuitem id="menu_test_questions" name="Questions" parent="menu_test_root" action="action_test_question" sequence="20"/>

        <!-- User Inputs/Responses Menu -->
        <menuitem id="menu_test_user_inputs" name="Responses" parent="menu_test_root" action="action_test_user_input" sequence="30"/>

        <!-- Participants Menu (Global - shows all participants across all tests) -->
        <menuitem id="menu_test_participants" name="Participants" parent="menu_test_root" action="action_test_user_input" sequence="40"/>

    </data>
</odoo>
